# =====================================================
# ОБЩИЙ .gitignore для Django + Vue.js проекта
# =====================================================

# -----------------------------------------------------
# Python виртуальное окружение
# -----------------------------------------------------
venv/
.venv/
env/
ENV/

# -----------------------------------------------------
# Python кэш и скомпилированные файлы
# -----------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyd
*.pyo
*.pyw

# -----------------------------------------------------
# Python сборка и дистрибуция
# -----------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.ruff_cache
.mypy_cache

# -----------------------------------------------------
# Django специфичное
# -----------------------------------------------------
media/
staticfiles/
static/
*.sqlite3
*.db
*.dump
*.backup
*.sql
db.sqlite3

# -----------------------------------------------------
# Node.js зависимости
# -----------------------------------------------------
node_modules/
.npm/
.yarn/
.yarnrc.yml
.pnpm-store/
.pnp.*

# -----------------------------------------------------
# Frontend сборка (Vue.js)
# -----------------------------------------------------
dist/
dist-ssr/
.temp/
.cache/
site/

# -----------------------------------------------------
# Package manager lock files
# -----------------------------------------------------
yarn.lock
bun.lockb
pnpm-lock.yaml
*.tgz

# -----------------------------------------------------
# Логи
# -----------------------------------------------------
*.log
debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log.*
logs/

# -----------------------------------------------------
# Переменные окружения
# -----------------------------------------------------
.env
.env
.env.local
.env.*.local
.env.production
.env.development
!.env.example
!.env.sample

# -----------------------------------------------------
# IDE и редакторы
# -----------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.swp
*.swo
*.sw?
*~

# -----------------------------------------------------
# Системные файлы
# -----------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.lnk
*.cab
*.msi

# -----------------------------------------------------
# Временные файлы
# -----------------------------------------------------
*.tmp
*.temp
*.pid
*.seed
*.pid.lock
~*
temp/

# -----------------------------------------------------
# Безопасность
# -----------------------------------------------------
*.pem
*.key
*.crt
.secret
*.secret
credentials.json
firebase.json

# -----------------------------------------------------
# Тестирование
# -----------------------------------------------------
coverage/
.nyc_output/
__snapshots__/
__screenshots__/
cypress/videos/
cypress/screenshots/
.eslintcache

# -----------------------------------------------------
# Прочее
# -----------------------------------------------------
*.bak
*.old
*.cache
*.zip
*.rar
*.tar
*.tar.gz
*.tgz
*.7z
*.rdb
docker-compose.override.yml
celerybeat-schedule*