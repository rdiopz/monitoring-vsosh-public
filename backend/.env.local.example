# =====================================================
# .env.local.example - Шаблон переменных окружения Django
# =====================================================
# ИНСТРУКЦИЯ:
# 1. Скопируйте этот файл в .env
# 2. Заполните все значения
# 3. НИКОГДА не коммитьте .env в Git!
# =====================================================

# ======================== БАЗОВЫЕ НАСТРОЙКИ ========================
DJANGO_SECRET_KEY=django-insecure-generate-new-secret-key-min-50-characters-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,monitoring-vsosh.ru,www.monitoring-vsosh.ru

# ======================== БАЗА ДАННЫХ PostgreSQL========================
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable or require

# ======================== REDIS ========================
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_URL=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2

# ======================== CELERY ========================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ======================== JWT ========================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ======================== CORS (IF DEBUG=FALSE) ========================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://monitoring-vsosh.ru,https://www.monitoring-vsosh.ru

# ======================== MEDIA ========================
MEDIA_ROOT=media

# =====================================================
# КОММЕНТАРИИ (можно удалить)
# =====================================================
# DJANGO_SECRET_KEY - Секретный ключ Django (сгенерируйте: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
# DEBUG - Режим отладки (True=разработка, False=продакшен)
# ALLOWED_HOSTS - Доверенные домены через запятую
# DB_NAME - Имя базы данных
# DB_USER - Пользователь БД
# DB_PASSWORD - Пароль БД (минимум 12 символов желательно)
# DB_HOST - Хост БД (localhost для локальной разработки)
# DB_PORT - Порт PostgreSQL (по умолчанию 5432)
# DB_SSLMODE - SSL режим (disable=локально, require=облачный хостинг)
# REDIS_URL - URL для основного Redis (Celery broker)
# REDIS_SESSION_URL - URL для JWT sessions
# REDIS_CACHE_URL - URL для кэширования Django
# CELERY_BROKER_URL - Адрес для получения задач
# CELERY_RESULT_BACKEND - Адрес для хранения результатов задач
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES - Время жизни access токена в минутах
# JWT_REFRESH_TOKEN_LIFETIME_DAYS - Время жизни refresh токена в днях
# CORS_ALLOWED_ORIGINS - Разрешённые домены для CORS (через запятую, без пробелов)
# MEDIA_ROOT - Папка для медиафайлов (относительно BASE_DIR)
